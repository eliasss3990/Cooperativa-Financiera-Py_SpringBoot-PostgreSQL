root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
trim_trailing_whitespace = true
insert_final_newline = true

[*.java]
indent_size = 4

[*.{xml}]
indent_size = 4

[*.{yml,yaml}]
indent_size = 2

[*.properties]
indent_size = 4

# En Markdown los espacios al final de línea son significativos
[*.md]
trim_trailing_whitespace = false
